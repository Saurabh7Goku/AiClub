rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ==================== HELPER FUNCTIONS ====================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isLeader() {
      return isAuthenticated() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['leader', 'admin'];
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function existingVote(ideaId) {
      return exists(/databases/$(database)/documents/votes/$(ideaId + "_" + request.auth.uid));
    }

    function isInClub(clubId) {
      return isAuthenticated() && (
        isAdmin() ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.joinedClubs.hasAny([clubId]))
      );
    }

    // ==================== COLLECTIONS ====================

    // Users collection
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) && 
        (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'reputationScore']) ||
         resource.data.role == request.resource.data.role) ||
        (isLeader() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reputationScore']));
      allow delete: if isAdmin();
    }

    // Bounties collection
    match /bounties/{bountyId} {
      allow read: if isAuthenticated();
      allow create: if isLeader() && 
        request.resource.data.clubId != null &&
        request.resource.data.createdBy.uid == request.auth.uid;
      allow update: if isLeader() && (
        resource.data.createdBy.uid == request.auth.uid ||
        isAdmin()
      );
      allow delete: if isAdmin();
    }

    // Ideas collection
    match /ideas/{ideaId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() &&
        request.resource.data.status == 'open' &&
        request.resource.data.voteScore == 0 &&
        request.resource.data.votesIn == 0 &&
        request.resource.data.votesOut == 0 &&
        request.resource.data.trendingVelocity == 0 &&
        'title' in request.resource.data &&
        'problemStatement' in request.resource.data &&
        'proposedAiUsage' in request.resource.data &&
        'submittedBy' in request.resource.data &&
        request.resource.data.submittedBy.uid == request.auth.uid;
      
      allow update: if isAuthenticated() && (
        resource.data.submittedBy.uid == request.auth.uid ||
        isLeader() ||
        (isInClub(resource.data.clubId) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['votesIn', 'votesOut', 'voteScore', 'trendingVelocity', 'updatedAt']))
      );
      
      allow delete: if isAdmin();
    }

    // Votes collection
    match /votes/{voteId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() &&
        request.resource.data.uid == request.auth.uid &&
        request.resource.data.vote in ['in', 'out'] &&
        !existingVote(request.resource.data.ideaId);
      
      allow update: if isAuthenticated() &&
        resource.data.uid == request.auth.uid &&
        request.resource.data.vote in ['in', 'out'];
      
      allow delete: if isAuthenticated() &&
        resource.data.uid == request.auth.uid;
    }

    // Tech feed collection
    match /tech_feed/{feedId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isLeader();
    }

    // Meetings collection
    match /meetings/{meetingId} {
      allow read: if isAuthenticated();
      allow create: if isLeader() &&
        'ideaId' in request.resource.data &&
        'organizerId' in request.resource.data &&
        'scheduledAt' in request.resource.data;
      allow update: if isLeader();
      allow delete: if isAdmin();
    }

    // AI Drafts collection
    match /ai_drafts/{draftId} {
      allow read: if isAuthenticated();
      allow create: if isLeader();
      allow update: if isLeader();
      allow delete: if isAdmin();
    }

    // Config collection (system settings)
    match /config/{configId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Clubs collection
    match /clubs/{clubId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() &&
        'name' in request.resource.data &&
        'description' in request.resource.data &&
        'joinKey' in request.resource.data &&
        'adminId' in request.resource.data &&
        request.resource.data.adminId == request.auth.uid;
      
      allow update: if isAuthenticated() && (
        resource.data.adminId == request.auth.uid ||
        isAdmin() ||
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['memberCount']) && 
         request.resource.data.memberCount == resource.data.memberCount + 1)
      );
      
      allow delete: if isAdmin();
    }

    // Meeting rooms collection (fixed 4 rooms per club)
    match /meeting_rooms/{roomId} {
      allow read: if isInClub(resource.data.clubId);
      allow create: if isLeader() && isInClub(request.resource.data.clubId);
      allow update: if isLeader() && isInClub(resource.data.clubId);
      allow delete: if isAdmin();
    }

    // Meeting sessions collection (active meetings)
    match /meeting_sessions/{meetingId} {
      allow read: if isInClub(resource.data.clubId);
      allow create: if isLeader() && isInClub(request.resource.data.clubId);
      allow update: if isLeader() && isInClub(resource.data.clubId);
      allow delete: if isAdmin();

      // Join requests subcollection
      match /join_requests/{userId} {
        allow read: if isInClub(get(/databases/$(database)/documents/meeting_sessions/$(meetingId)).data.clubId);
        allow create: if isAuthenticated() && request.auth.uid == userId &&
          isInClub(request.resource.data.clubId);
        allow update: if isLeader() && isInClub(get(/databases/$(database)/documents/meeting_sessions/$(meetingId)).data.clubId);
        allow delete: if isAdmin();
      }

      // Presence subcollection (for cursors and activity)
      match /presence/{userId} {
        allow read: if isAuthenticated();
        allow create, update, delete: if isAuthenticated() && request.auth.uid == userId;
      }
    }

    // Meeting boards collection (shared document state)
    match /meeting_boards/{meetingId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated();
      allow delete: if isAdmin();

      // Yjs subcollections for real-time collaboration
      match /yjs_updates/{updateId} {
        allow read, write: if isAuthenticated();
      }
      match /yjs_awareness/{clientId} {
        allow read, write: if isAuthenticated();
      }
    }

    // Individual delta operations for the board
    match /meeting_board_ops/{meetingId}/ops/{opId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow delete: if isAdmin();
    }

    // Meeting outputs collection
    match /meeting_outputs/{outputId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated();
      allow delete: if isAdmin();
    }

    // Meeting canvases collection
    match /meeting_canvases/{meetingId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated();
      allow delete: if isAdmin();
    }

    // Project canvases collection
    match /project_canvases/{canvasId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated();
      allow delete: if isAdmin();
    }

    // Comments collection
    match /comments/{commentId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() &&
        request.resource.data.uid == request.auth.uid;
      allow delete: if isAdmin() || resource.data.uid == request.auth.uid;
    }

    // --- Communication & Discussions ---

    // Channels collection
    match /channels/{channelId} {
      allow read: if isInClub(resource.data.clubId);
      allow create: if isLeader() && isInClub(request.resource.data.clubId);
      allow update: if isLeader() && isInClub(resource.data.clubId);
      allow delete: if isAdmin();
    }

    // Messages collection
    match /messages/{messageId} {
      allow read: if isInClub(resource.data.clubId);
      allow create: if isAuthenticated() && 
        isInClub(request.resource.data.clubId) &&
        request.resource.data.uid == request.auth.uid &&
        (get(/databases/$(database)/documents/channels/$(request.resource.data.channelId)).data.type != 'announcement' || isLeader());
      allow update: if isAuthenticated() && (
        resource.data.uid == request.auth.uid || 
        (isInClub(resource.data.clubId) && 
         request.resource.data.diff(resource.data).affectedKeys().hasAny(['reactions', 'pollData', 'replyCount'])) ||
        isLeader()
      );
      allow delete: if isAdmin() || resource.data.uid == request.auth.uid;
    }

    // Projects collection
    match /projects/{projectId} {
      allow read: if isAuthenticated() && (
        isInClub(resource.data.clubId) ||
        request.auth.uid in resource.data.members
      );
      allow create: if isLeader() && isInClub(request.resource.data.clubId);
      allow update: if isInClub(resource.data.clubId) ||
        (isAuthenticated() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['members']) &&
         request.resource.data.members.hasAll(resource.data.members) &&
         request.auth.uid in request.resource.data.members);
      allow delete: if isAdmin();
    }

    // Tasks collection
    match /tasks/{taskId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated();
      allow delete: if isLeader();
    }

    // Milestones collection
    match /milestones/{milestoneId} {
      allow read: if isAuthenticated();
      allow create, update: if isLeader();
      allow delete: if isAdmin();
    }

    // Notifications collection
    match /notifications/{notificationId} {
      allow read: if isAuthenticated() && resource.data.recipientId == request.auth.uid;
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && resource.data.recipientId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.recipientId == request.auth.uid;
    }

    // Wiki articles collection
    match /wiki_articles/{articleId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isInClub(request.resource.data.clubId);
      allow update: if isAuthenticated() && isInClub(resource.data.clubId);
      allow delete: if isLeader();
    }

    // Club events collection
    match /club_events/{eventId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isInClub(request.resource.data.clubId);
      allow update: if isAuthenticated() && isInClub(resource.data.clubId);
      allow delete: if isLeader();
    }

    // Integration settings collection (Teams/Slack webhooks)
    match /integration_settings/{clubId} {
      allow read: if isAuthenticated() && isInClub(clubId);
      allow create, update: if isLeader() && isInClub(clubId);
      allow delete: if isAdmin();
    }

    // Wiki versions collection (version history)
    match /wiki_versions/{versionId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow delete: if isLeader();
    }

    // Calendar integrations collection (per-user OAuth tokens)
    match /calendar_integrations/{integrationId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create, update: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }
  }
}
